################################################################################
# LINGAYAT SANGAM MATRIMONIAL PLATFORM
# Environment Configuration (.env.local)
################################################################################
# IMPORTANT SECURITY NOTES:
# - NEVER commit .env.local to version control
# - .env.local is listed in .gitignore for protection
# - Copy this file to .env.local and fill in your actual keys
# - Use different keys for development and production
# - Rotate keys regularly for security
################################################################################

# ═══════════════════════════════════════════════════════════════════════════
# REQUIRED: SUPABASE CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT_ID/settings/api
# These are REQUIRED for the app to function
# - VITE_SUPABASE_URL: Your Supabase project URL (looks like: https://xxx.supabase.co)
# - VITE_SUPABASE_ANON_KEY: Public anonymous key (safe to expose in frontend)

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here


# ═══════════════════════════════════════════════════════════════════════════
# OPTIONAL: GOOGLE GEMINI API (AI Bio Generation)
# ═══════════════════════════════════════════════════════════════════════════
# Get this from: https://aistudio.google.com/app/apikey
# Used for: AI-powered profile bio generation
# Leave empty to disable AI bio generator features
# Status: Currently not actively used in core features

VITE_GEMINI_API_KEY=your_gemini_api_key_here


# ═══════════════════════════════════════════════════════════════════════════
# OPTIONAL: SENTRY ERROR TRACKING & MONITORING
# ═══════════════════════════════════════════════════════════════════════════
# Get this from: https://sentry.io/settings/projects/YOUR_ORG/YOUR_PROJECT/client-keys/
# Used for: Production error tracking, crash reporting, performance monitoring
# - Leave empty to disable Sentry (no error tracking)
# - Only active in production builds
# - Development builds ignore Sentry configuration

VITE_SENTRY_DSN=https://your_sentry_dsn_here@your_org.ingest.sentry.io/your_project_id


# ═══════════════════════════════════════════════════════════════════════════
# OPTIONAL: APPLICATION VERSIONING
# ═══════════════════════════════════════════════════════════════════════════
# Used for: Error tracking, debugging, release management
# Format: semantic versioning (MAJOR.MINOR.PATCH)
# Update this with each release for tracking purposes

VITE_APP_VERSION=0.0.0


# ═══════════════════════════════════════════════════════════════════════════
# FUTURE: ADDITIONAL CONFIGURATION (Reserved for future use)
# ═══════════════════════════════════════════════════════════════════════════
# Uncomment and configure these when implementing additional features:

# Google Drive API (for photo storage)
# VITE_GOOGLE_DRIVE_API_KEY=your_google_drive_api_key_here

# Razorpay Payment Gateway (for subscriptions)
# VITE_RAZORPAY_KEY_ID=your_razorpay_key_id_here

# SendGrid Email Service (for notifications)
# VITE_SENDGRID_API_KEY=your_sendgrid_api_key_here

# Analytics (Google Analytics, Mixpanel, etc.)
# VITE_GA_TRACKING_ID=your_ga_tracking_id_here


# ═══════════════════════════════════════════════════════════════════════════
# SETUP INSTRUCTIONS
# ═══════════════════════════════════════════════════════════════════════════
#
# 1. Copy this file to .env.local:
#    cp .env.example .env.local
#
# 2. Update .env.local with your actual configuration values:
#    - Supabase: https://supabase.com/dashboard
#    - Sentry (optional): https://sentry.io
#    - Google Gemini (optional): https://aistudio.google.com
#
# 3. NEVER commit .env.local to version control
#
# 4. For team members: Share configuration via secure channel
#    (e.g., password manager, encrypted email, or team wiki)
#
# 5. Test configuration:
#    npm run dev
#    Check browser console for any errors related to missing environment variables
#
# ═══════════════════════════════════════════════════════════════════════════
# ENVIRONMENT-SPECIFIC SETUP
# ═══════════════════════════════════════════════════════════════════════════
#
# Development (.env.local):
#   - Use Supabase development project or staging environment
#   - Disable Sentry or use test DSN (won't pollute production data)
#   - Use test API keys
#
# Production (.env.production.local):
#   - Use Supabase production project
#   - Enable Sentry with production DSN
#   - Use production API keys
#   - Store securely (environment variables, secrets manager, etc.)
#
# ═══════════════════════════════════════════════════════════════════════════
# TROUBLESHOOTING
# ═══════════════════════════════════════════════════════════════════════════
#
# "Cannot find module 'import.meta.env'" error:
#   → Your .env.local file is missing or has invalid format
#   → Ensure tsconfig.json includes "vite/client" in types
#
# Environment variables showing as "undefined" in browser:
#   → Only variables prefixed with VITE_ are exposed to frontend
#   → Check variable names match exactly (case-sensitive)
#   → Restart dev server after .env.local changes
#
# Supabase connection fails:
#   → Verify VITE_SUPABASE_URL is correct (check project settings)
#   → Verify VITE_SUPABASE_ANON_KEY is valid
#   → Check network connectivity
#
# ═══════════════════════════════════════════════════════════════════════════
