{
  "name": "lingayat-matrimonial-api",
  "version": "1.0.0",
  "description": "Backend API for Lingayat Mali Matrimonial App",
  "main": "src/app.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/app.js",
    "start": "node src/app.js",
    "test": "jest --detectOpenHandles --forceExit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --fix",
    "db:migrate": "node src/migrations/run.js",
    "db:seed": "node src/migrations/seed.js",
    "seed:data": "node scripts/seedTestData.js",
    "build": "echo 'Build not needed for Node.js'",
    "docker:build": "docker build -t matrimonial-api .",
    "docker:run": "docker run -p 3000:3000 --env-file .env matrimonial-api"
  },
  "keywords": [
    "matrimonial",
    "api",
    "lingayat",
    "dating"
  ],
  "author": "Your Team",
  "license": "PRIVATE",
  "dependencies": {
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "pg": "^8.10.0",
    "sequelize": "^6.35.0",
    "jsonwebtoken": "^9.1.2",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.3.1",
    "joi": "^17.11.0",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "morgan": "^1.10.0",
    "google-auth-library": "^9.4.1",
    "googleapis": "^118.0.0",
    "razorpay": "^2.9.1",
    "nodemailer": "^6.9.7",
    "axios": "^1.6.2",
    "moment": "^2.29.4",
    "compression": "^1.7.4",
    "express-slow-down": "^2.0.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "validator": "^13.11.0",
    "sharp": "^0.33.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "dotenv-cli": "^7.3.0",
    "@types/jest": "^29.5.10",
    "jest-extended": "^4.0.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lingayat-matrimonial/api.git"
  }
}
