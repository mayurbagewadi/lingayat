# NODE ENVIRONMENT
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000

# DATABASE
DB_HOST=localhost
DB_PORT=5432
DB_NAME=lingayat_matrimonial
DB_USER=postgres
DB_PASSWORD=your_secure_password
DB_DIALECT=postgres
DB_POOL_MIN=2
DB_POOL_MAX=10

# JWT SECRETS
JWT_ACCESS_SECRET=your_very_long_random_secret_key_minimum_32_characters
JWT_REFRESH_SECRET=your_very_long_random_refresh_secret_key_minimum_32_characters
JWT_ACCESS_EXPIRY=1h
JWT_REFRESH_EXPIRY=30d

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:5173,https://matrimonial.local

# RATE LIMITING
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_MAX_REQUESTS_AUTH=1000

# LOGGING
LOG_LEVEL=debug
LOG_FORMAT=json
LOG_FILE=logs/app.log

# GOOGLE DRIVE INTEGRATION
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google-drive/callback
GOOGLE_SCOPES=https://www.googleapis.com/auth/drive https://www.googleapis.com/auth/drive.file

# GOOGLE SERVICE ACCOUNT (for backend operations)
GOOGLE_SERVICE_ACCOUNT_EMAIL=service-account@project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nYourPrivateKey\n-----END PRIVATE KEY-----
GOOGLE_SERVICE_ACCOUNT_PROJECT_ID=your_project_id

# RAZORPAY INTEGRATION
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# EMAIL SERVICE (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_specific_password
EMAIL_FROM=noreply@matrimonial.local
EMAIL_FROM_NAME=Lingayat Matrimonial

# SMS SERVICE (Optional - Twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# WHATSAPP SERVICE (Optional)
WHATSAPP_API_URL=https://api.whatsapp.com/send
WHATSAPP_TOKEN=your_whatsapp_token

# FILE UPLOAD
MAX_FILE_SIZE=52428800
UPLOAD_TEMP_DIR=/tmp/uploads
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/jpg
ALLOWED_PDF_TYPES=application/pdf

# ADMIN SETTINGS
ADMIN_EMAIL=admin@matrimonial.local
ADMIN_PASSWORD=change_in_production

# SECURITY
ENCRYPTION_KEY=your_32_character_encryption_key
ENCRYPTION_IV=your_16_character_iv

# PAYMENT SETTINGS
SUBSCRIPTION_PLAN_ID=plan_premium_yearly
SUBSCRIPTION_PRICE_INR=2999.00
SUBSCRIPTION_DURATION_MONTHS=12

# FEATURE FLAGS
ENABLE_MANUAL_PAYMENT=true
ENABLE_SMS_NOTIFICATIONS=false
ENABLE_WHATSAPP_NOTIFICATIONS=false
REQUIRE_EMAIL_VERIFICATION=true
AUTO_DELETE_UNVERIFIED_AFTER_DAYS=7

# SENTRY ERROR TRACKING (Optional)
SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id

# DATABASE BACKUP
BACKUP_SCHEDULE=0 2 * * * (2 AM daily)
BACKUP_RETENTION_DAYS=30

# REDIS (Optional - for caching/sessions)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# MONITORING
MONITORING_ENABLED=true
METRICS_PORT=9090
